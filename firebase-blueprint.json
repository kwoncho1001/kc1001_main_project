{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "onboardingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "AbilityScore": {
      "title": "Ability Score",
      "description": "User ability score for a specific skill node",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Skill node ID" },
        "name": { "type": "string" },
        "level": { "type": "string", "enum": ["L1", "L2", "L3", "L4", "L5"] },
        "score": { "type": "number" },
        "lastUpdated": { "type": "number" },
        "solvedProblemCount": { "type": "number" }
      },
      "required": ["id", "score", "lastUpdated"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A bookmarked problem",
      "type": "object",
      "properties": {
        "problemId": { "type": "string" },
        "title": { "type": "string" },
        "bookmarkedAt": { "type": "number" }
      },
      "required": ["problemId", "bookmarkedAt"]
    },
    "GamificationStats": {
      "title": "Gamification Stats",
      "description": "User gamification metrics",
      "type": "object",
      "properties": {
        "solvedCount": { "type": "number" },
        "avgDifficulty": { "type": "number" },
        "accuracy": { "type": "number" },
        "streakDays": { "type": "number" },
        "totalPoints": { "type": "number" },
        "level": { "type": "number" },
        "treeGrowth": { "type": "number" }
      },
      "required": ["totalPoints", "level"]
    },
    "TransactionLog": {
      "title": "Transaction Log",
      "description": "A log of a student's problem solving attempt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "problemId": { "type": "string" },
        "isCorrect": { "type": "boolean" },
        "timeSpentMs": { "type": "number" },
        "difficulty": { "type": "number" },
        "timestamp": { "type": "number" },
        "hierarchyPath": { "type": "string" }
      },
      "required": ["id", "studentId", "problemId", "isCorrect", "timestamp"]
    },
    "ProgressMaster": {
      "title": "Progress Master",
      "description": "Aggregated progress data for a student at a specific hierarchy node",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "hierarchyId": { "type": "string" },
        "level": { "type": "string" },
        "currentScore": { "type": "number" },
        "totalAttempts": { "type": "number" },
        "correctAttempts": { "type": "number" },
        "lastAttemptTimestamp": { "type": "number" },
        "trend": { "type": "string", "enum": ["UP", "DOWN", "STABLE"] }
      },
      "required": ["studentId", "hierarchyId", "currentScore"]
    },
    "Question": {
      "title": "Question",
      "description": "A mathematical problem with metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string", "description": "LaTeX content" },
        "answer": { "type": "string" },
        "difficulty": { "type": "number", "minimum": 1, "maximum": 5 },
        "fieldId": { "type": "string" },
        "subjectId": { "type": "string" },
        "majorUnitId": { "type": "string" },
        "minorUnitId": { "type": "string" },
        "tagId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "content", "answer", "difficulty", "tagId"]
    }
  },
  "firestore": {
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global question database"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/abilityScores/{scoreId}": {
      "schema": "AbilityScore",
      "description": "User's ability scores"
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's bookmarked problems"
    },
    "/users/{userId}/gamification/stats": {
      "schema": "GamificationStats",
      "description": "User's gamification statistics"
    },
    "/users/{userId}/transactionLogs/{logId}": {
      "schema": "TransactionLog",
      "description": "User's learning transaction logs"
    },
    "/users/{userId}/progressMaster/{progressId}": {
      "schema": "ProgressMaster",
      "description": "User's aggregated progress data"
    }
  }
}
